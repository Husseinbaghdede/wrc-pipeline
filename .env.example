# ===========================================
# WRC Scraper Pipeline - Configuration
# ===========================================
# Copy this file to .env and adjust values

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=wrc_scraper
MONGO_LANDING_COLLECTION=landing_metadata
MONGO_TRANSFORMED_COLLECTION=transformed_metadata

# --- MinIO (S3-compatible object storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_LANDING_BUCKET=landing-zone
MINIO_TRANSFORMED_BUCKET=transformed-zone

# --- Scraping Parameters ---
PARTITION_SIZE=monthly
DOWNLOAD_DELAY=1.5
CONCURRENT_REQUESTS=4
RETRY_TIMES=3
LOG_LEVEL=INFO

# --- Paths ---
LOG_PATH=./logs
